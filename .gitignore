# =============================================================================
# DukanSathi — Git Ignore Rules
# =============================================================================

# --- Secrets & Environment ---
.env
*.env
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.pyc
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual Environment ---
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# --- Uploaded PDFs & FAISS Index (runtime data — keep directory structure) ---
backend/uploads/*
!backend/uploads/.gitkeep
backend/vectorstore/*
!backend/vectorstore/.gitkeep
uploads/*
!uploads/.gitkeep
vectorstore/*
!vectorstore/.gitkeep

# --- HuggingFace model cache ---
backend/cache/
cache/

# --- Scratch / test files ---
backend/test_openrouter.py
test_warranty.pdf

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Vite / Frontend Build ---
frontend/dist/
frontend/.vite/
dist/
.vite/

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/
